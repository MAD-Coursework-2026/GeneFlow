<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_patient_row"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- Patient name column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2.2"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_chevron_down"
            android:contentDescription="expand" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_person"
            android:contentDescription="patient" />

        <TextView
            android:id="@+id/txtName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Patient"
            android:textColor="@color/text_primary"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Status dot -->
    <View
        android:id="@+id/statusDot"
        android:layout_width="0dp"
        android:layout_weight="0.8"
        android:layout_height="14dp"
        android:layout_gravity="center"
        android:background="@drawable/status_dot_red" />

    <!-- Actions -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.6"
        android:gravity="end|center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/btnReport"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_report"
            android:contentDescription="report" />

        <ImageView
            android:id="@+id/btnUpload"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_upload_cloud"
            android:contentDescription="upload" />

        <ImageView
            android:id="@+id/btnFamily"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_family"
            android:contentDescription="family" />

        <ImageView
            android:id="@+id/btnDelete"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_trash"
            android:contentDescription="delete" />
    </LinearLayout>
</LinearLayout>

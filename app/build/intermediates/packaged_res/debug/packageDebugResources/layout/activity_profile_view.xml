<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="14dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_back"
                android:contentDescription="@string/back" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/profile_view"
                android:textColor="@color/dark_teal"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Identity card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AHMED KHAN"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtPatientId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ID #01637357747"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/txtAge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Age: 32"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Demographics -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="6dp"
            android:text="@string/demographics"
            android:textColor="@color/dark_teal"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView android:id="@+id/txtGender" style="@style/RowLine" android:text="Gender:  Male" />
            <TextView android:id="@+id/txtBlood" style="@style/RowLine" android:text="Blood Group:  B+" />
            <TextView android:id="@+id/txtContact" style="@style/RowLine" android:text="Contact:  0300-XXXXXXX" />
            <TextView android:id="@+id/txtCity" style="@style/RowLine" android:text="City:  Lahore" />
            <TextView android:id="@+id/txtAddress" style="@style/RowLine" android:text="Address:  Izmir Town Lahore" />
        </LinearLayout>

        <!-- Medical history -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="6dp"
            android:text="@string/medical_history"
            android:textColor="@color/dark_teal"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView android:id="@+id/txtReason" style="@style/RowLine"
                android:text="Reason:  Heavy maternal family history of early onset breast-cancer" />
            <TextView android:id="@+id/txtAllergies" style="@style/RowLine" android:text="Allergies:  None Known" />
            <TextView android:id="@+id/txtMeds" style="@style/RowLine" android:text="Medications:  Baseline supplements" />
        </LinearLayout>

        <!-- ACMG status -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="6dp"
            android:text="@string/current_acmg"
            android:textColor="@color/dark_teal"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtAcmg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_white"
            android:padding="16dp"
            android:text="POSITIVE | BRCA1 Pathogenic"
            android:textColor="@color/status_red"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Genome dispatcher -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="6dp"
            android:text="@string/genome_dispatcher"
            android:textColor="@color/dark_teal"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/btnUploadVcf"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_field_white"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_upload_cloud"
                android:contentDescription="@string/upload_new_vcf" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/upload_new_vcf"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- View pedigree -->
        <TextView
            android:id="@+id/btnViewPedigree"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_button_teal"
            android:gravity="center"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:text="@string/view_full_pedigree"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
